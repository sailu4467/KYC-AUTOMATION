        <script><![CDATA[var KYCRiskCalculator = Class.create();
KYCRiskCalculator.prototype = {
    calculateRisk: function(record) {
        var score = 0;

        if (record.pep_flag) score += 30;
        if (record.sanctions_flag) score += 40;
        if (record.adverse_media_flag) score += 15;

        score += (record.transaction_risk_score || 0) * 1.5;

        return score;
    }
};]]></script>
